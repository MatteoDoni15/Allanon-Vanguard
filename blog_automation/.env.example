# Copy this file to .env and fill in real values.
# With no .env at all, the project runs in full mock mode (no API key needed).

# --- LLM provider ------------------------------------------------------
# "mock" (default, no key needed) | "anthropic" | "openai"
LLM_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2200
LLM_TEMPERATURE=0.6

# --- Brand context -------------------------------------------------------
COMPANY_NAME=NorthLedger Finance

# --- Publishing (WordPress REST API example) ----------------------------
# Leave DRY_RUN_PUBLISH=true to write HTML+JSON to outputs/ instead of
# making a real HTTP call (used for local dev, demos, and grading).
DRY_RUN_PUBLISH=true
WP_BASE_URL=https://www.example-fintech.com
WP_USERNAME=
WP_APP_PASSWORD=
